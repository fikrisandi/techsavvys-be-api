# Nginx config untuk api.techsavvys-official.com
# Tambahkan ke /etc/nginx/sites-enabled/default di server
#
# Pastikan sudah generate SSL cert:
#   certbot certonly --nginx -d api.techsavvys-official.com
#
# Pastikan port 4000 sudah di-publish di Docker/Dokploy:
#   docker service update --publish-add 4000:4000 <service-name>
#
# Setelah tambah config, test dan reload:
#   nginx -t && systemctl reload nginx

server {
    server_name api.techsavvys-official.com;

    location / {
        # Handle preflight OPTIONS requests
        if ($request_method = 'OPTIONS') {
            add_header 'Access-Control-Allow-Origin' $http_origin always;
            add_header 'Access-Control-Allow-Methods' 'GET, POST, PUT, PATCH, DELETE, OPTIONS' always;
            add_header 'Access-Control-Allow-Headers' 'Content-Type, Authorization' always;
            add_header 'Access-Control-Allow-Credentials' 'true' always;
            add_header 'Access-Control-Max-Age' 86400;
            add_header 'Content-Length' 0;
            return 204;
        }

        proxy_pass             http://localhost:4000;
        proxy_http_version     1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Pass CORS headers from upstream
        proxy_pass_header Access-Control-Allow-Origin;
        proxy_pass_header Access-Control-Allow-Methods;
        proxy_pass_header Access-Control-Allow-Headers;
        proxy_pass_header Access-Control-Allow-Credentials;
    }

    listen [::]:443 ssl;
    listen 443 ssl;
    ssl_certificate     /etc/letsencrypt/live/api.techsavvys-official.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.techsavvys-official.com/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;
}

server {
    if ($host = api.techsavvys-official.com) {
        return 301 https://$host$request_uri;
    }

    listen 80;
    listen [::]:80;
    server_name api.techsavvys-official.com;
    return 404;
}
