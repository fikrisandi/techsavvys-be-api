# Nginx config untuk api.techsavvys-official.com
# Tambahkan ke /etc/nginx/sites-enabled/default di server
#
# Pastikan sudah generate SSL cert:
#   certbot certonly --nginx -d api.techsavvys-official.com
#
# Pastikan port 4000 sudah di-publish di Docker/Dokploy:
#   docker service update --publish-add 4000:4000 <service-name>
#
# Setelah tambah config, test dan reload:
#   nginx -t && systemctl reload nginx

server {
    server_name api.techsavvys-official.com;

    location / {
        proxy_pass             http://localhost:4000;
        proxy_http_version     1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    listen [::]:443 ssl;
    listen 443 ssl;
    ssl_certificate     /etc/letsencrypt/live/api.techsavvys-official.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.techsavvys-official.com/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;
}

server {
    if ($host = api.techsavvys-official.com) {
        return 301 https://$host$request_uri;
    }

    listen 80;
    listen [::]:80;
    server_name api.techsavvys-official.com;
    return 404;
}
