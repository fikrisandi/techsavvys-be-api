# Database — multi-schema (platform, marketing, invitation)
# Pakai 1 Postgres bersama dengan home-keep-be (DB: techsavvys_platform).
# `schema=platform` jadi default search-path; Prisma tetap pakai semua 3 schema.
# User Postgres butuh privilege CREATE/USAGE pada platform, marketing, invitation.
DATABASE_URL="postgresql://techsavvys_user:CHANGE_ME@postgres-shared:5432/techsavvys_platform?schema=platform"

JWT_SECRET="your-jwt-secret"
JWT_REFRESH_SECRET="your-refresh-secret"
PORT=4000

# CORS - comma-separated list of allowed origins
CORS_ORIGINS="https://techsavvys.com,https://www.techsavvys.com,https://techsavvys-official.com,https://www.techsavvys-official.com,https://invitation.techsavvys.com"

# Frontend invitation URL (for generating shareable links)
INVITATION_BASE_URL="https://invitation.techsavvys-official.com"
