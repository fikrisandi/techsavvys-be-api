generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["platform", "marketing", "invitation"]
}

// =====================================================
// schema: platform
// Identity, auth, dan apapun yang dipakai lintas produk
// =====================================================

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  password      String
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]

  @@schema("platform")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@schema("platform")
}

// =====================================================
// schema: marketing
// Konten company website Tech Savvys
// =====================================================

model Portfolio {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String
  imageUrl    String?
  techStack   String[]
  clientName  String?
  projectUrl  String?
  isFeatured  Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("marketing")
}

model Testimonial {
  id        String   @id @default(uuid())
  name      String
  role      String
  content   String
  rating    Int?
  avatarUrl String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("marketing")
}

model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String
  whatsapp  String
  service   String
  budget    String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@schema("marketing")
}

// =====================================================
// schema: invitation
// Produk wedding invitation
// =====================================================

model Invitation {
  id            String   @id @default(uuid())
  slug          String   @unique
  theme         String
  customColors  Json?
  expiredAt     DateTime
  openingText   String?
  groomNickname String
  groomFullName String
  groomParents  String
  groomPhoto    String?
  brideNickname String
  brideFullName String
  brideParents  String
  bridePhoto    String?
  akad          Json?
  receptions    Json     @default("[]")
  photos        Json     @default("[]")
  banks         Json     @default("[]")
  musicUrl      String?
  rsvpEnabled   Boolean  @default(true)
  wishesEnabled Boolean  @default(true)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  rsvps         Rsvp[]
  guests        Guest[]

  @@schema("invitation")
}

model Guest {
  id           String     @id @default(uuid())
  invitationId String
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  name         String
  receptions   String[]
  createdAt    DateTime   @default(now())

  @@schema("invitation")
}

model Rsvp {
  id           String     @id @default(uuid())
  invitationId String
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  name         String
  attendance   String
  guests       Int        @default(1)
  message      String?
  createdAt    DateTime   @default(now())

  @@schema("invitation")
}
